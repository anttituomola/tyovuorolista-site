---
const { locale = 'fi', translations = {} } = Astro.props

const title = translations.title ?? 'Haluan kysyä lisää!'
const description = translations.description ?? ''
const emailPlaceholder = translations.emailPlaceholder ?? ''
const phonePlaceholder = translations.phonePlaceholder ?? ''
const orLabel = translations.or ?? 'tai'
const submitLabel = translations.submit ?? 'Lähetä'
const successMessage = translations.success ?? ''
const errorMessage = translations.error ?? ''
const errorNetworkMessage = translations.errorNetwork ?? ''
---

<section class="contact-form" data-contact-form lang={locale}>
  <div class="contact-form__panel" data-contact-form-panel>
    <h2 class="contact-form__title">{title}</h2>
    <p class="contact-form__description">{description}</p>
    <form class="contact-form__fields" data-contact-form-fields novalidate>
      <label class="contact-form__field">
        <span class="visually-hidden">{emailPlaceholder}</span>
        <input
          type="email"
          name="email"
          data-contact-email
          autocomplete="email"
          placeholder={emailPlaceholder}
        />
      </label>
      <span class="contact-form__or">{orLabel}</span>
      <label class="contact-form__field">
        <span class="visually-hidden">{phonePlaceholder}</span>
        <input
          type="tel"
          name="phone"
          data-contact-phone
          autocomplete="tel"
          placeholder={phonePlaceholder}
        />
      </label>
      <button type="submit" class="contact-form__submit" data-contact-submit>
        {submitLabel}
      </button>
    </form>
  </div>
  <div class="contact-form__success" data-contact-form-success hidden>
    <h2 class="contact-form__title">{successMessage}</h2>
  </div>
</section>

<script
  define:vars={{
    errorMessage,
    errorNetworkMessage,
  }}
>
  const initContactForms = () => {
    document.querySelectorAll('[data-contact-form]').forEach((root) => {
      if (root.getAttribute('data-contact-initialized') === 'true') {
        return
      }
      root.setAttribute('data-contact-initialized', 'true')

      const form = root.querySelector('[data-contact-form-fields]')
      const panel = root.querySelector('[data-contact-form-panel]')
      const success = root.querySelector('[data-contact-form-success]')
      const submitBtn = root.querySelector('[data-contact-submit]')
      const emailInput = root.querySelector('[data-contact-email]')
      const phoneInput = root.querySelector('[data-contact-phone]')

      if (!form || !panel || !success || !submitBtn || !emailInput || !phoneInput) {
        return
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault()
        const email = emailInput.value.trim()
        const phone = phoneInput.value.trim()

        if (!email && !phone) {
          return
        }

        submitBtn.disabled = true

        try {
          const isDev =
            window.location.hostname === 'localhost' ||
            window.location.hostname === '127.0.0.1'
          const apiUrl = isDev
            ? '/api/handleForm'
            : 'https://www.tyovuorolista.fi/api/handleForm'

          const response = await fetch(apiUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, phone }),
          })

          if (!response.ok) {
            alert(errorMessage)
            return
          }

          const jsonResponse = await response.json()

          if (jsonResponse.status === 'success') {
            panel.hidden = true
            success.hidden = false
          } else {
            alert(errorMessage)
          }
        } catch {
          alert(errorNetworkMessage)
        } finally {
          submitBtn.disabled = false
        }
      })
    })
  }

  initContactForms()
  document.addEventListener('astro:page-load', initContactForms)
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: var(--space-2xl) auto 0;
    width: 100%;
    max-width: 600px;
    padding: var(--space-xl) var(--space-lg);
    box-sizing: border-box;
    text-align: center;
  }

  .contact-form__panel {
    width: 100%;
    background-color: var(--hiekka);
    border-radius: 8px;
    padding: var(--space-2xl) var(--space-xl);
    box-sizing: border-box;
  }

  .contact-form__title {
    margin: 0 0 var(--space-base);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--tummanvihrea);
    line-height: 1.2;
  }

  .contact-form__description {
    margin: 0 auto var(--space-xl);
    max-width: 400px;
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--tummanvihrea);
    line-height: 1.5;
  }

  .contact-form__fields {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .contact-form__field {
    width: 100%;
    max-width: 400px;
  }

  .contact-form__field input {
    width: 100%;
    padding: 1rem;
    border-radius: 2px;
    border: 1px solid var(--ruskeaharmaa);
    background-color: #f6f6f6;
    color: var(--tummanvihrea);
    font-size: var(--text-base);
    font-family: inherit;
    box-sizing: border-box;
  }

  .contact-form__field input:focus {
    outline: none;
    background-color: #fff;
    border-color: var(--tummanvihrea);
  }

  .contact-form__or {
    color: var(--tummanvihrea);
    font-weight: 500;
  }

  .contact-form__submit {
    padding: 1rem 1.5rem;
    min-width: 150px;
    border-radius: 2px;
    border: none;
    color: white;
    background-color: var(--tummanvihrea);
    font-size: var(--text-base);
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  .contact-form__submit:hover:not(:disabled) {
    background-color: var(--harmaa);
  }

  .contact-form__submit:disabled {
    background-color: var(--harmaa);
    cursor: wait;
  }

  .contact-form__success {
    width: 100%;
    background-color: var(--hiekka);
    border-radius: 8px;
    padding: var(--space-2xl) var(--space-xl);
    box-sizing: border-box;
  }

  .contact-form__success[hidden],
  .contact-form__panel[hidden] {
    display: none !important;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .contact-form__title {
      font-size: var(--text-2xl);
    }
  }
</style>
