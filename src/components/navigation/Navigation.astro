---
import Button from '../common/Button.astro'
import LanguageSwitcher from '../common/LanguageSwitcher.astro'
import { Image } from 'astro:assets'
import logo from '../../assets/logo.png'
import { t, getLocalizedPath, getActiveNavItem } from '../../utils/translations'

const { locale = 'fi' } = Astro.props

const activeNav = getActiveNavItem(Astro.url.pathname)

const homePath = locale === 'fi' ? '/' : `/${locale}`
const featuresPath = getLocalizedPath('/ominaisuudet', locale as 'fi' | 'en' | 'sv')
const pricingPath = getLocalizedPath('/hinnoittelu', locale as 'fi' | 'en' | 'sv')
const contactPath = getLocalizedPath('/yhteystiedot', locale as 'fi' | 'en' | 'sv')
---

<nav class='nav'>
    <div class='nav-container'>
        <a
            href={homePath}
            class:list={['logo', { 'logo--active': activeNav === 'home' }]}
            aria-current={activeNav === 'home' ? 'page' : undefined}
        >
            <Image src={logo} alt="tyovuorolista.fi logo" class="logo-symbol" quality="max" />
            <div class="logo-text">
                <h1>Tyovuorolista.fi</h1>
                <h4>{t('nav.logoSubtitle', locale as 'fi' | 'en' | 'sv')}</h4>
            </div>
        </a>

        <button
            type="button"
            class='mobile-menu-btn'
            aria-label={t('nav.openMenu', locale as 'fi' | 'en' | 'sv')}
            aria-expanded="false"
            aria-controls="site-nav-menu"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class='nav-menu' id="site-nav-menu">
            <div class='nav-links'>
                <a
                    href={featuresPath}
                    class:list={['navLink', { 'navLink--active': activeNav === 'features' }]}
                    aria-current={activeNav === 'features' ? 'page' : undefined}
                >{t('nav.features', locale as 'fi' | 'en' | 'sv')}</a>
                <a
                    href={pricingPath}
                    class:list={['navLink', { 'navLink--active': activeNav === 'pricing' }]}
                    aria-current={activeNav === 'pricing' ? 'page' : undefined}
                >{t('nav.pricing', locale as 'fi' | 'en' | 'sv')}</a>
                <a
                    href={contactPath}
                    class:list={['navLink', { 'navLink--active': activeNav === 'contact' }]}
                    aria-current={activeNav === 'contact' ? 'page' : undefined}
                >{t('nav.contact', locale as 'fi' | 'en' | 'sv')}</a>
            </div>

            <div class='nav-actions'>
                <LanguageSwitcher />
                <div class='buttonContainer'>
                    <Button variant="primary" locale={locale} />
                    <Button variant="secondary" href='https://app.tyovuorolista.fi/login' text={t('nav.login', locale as 'fi' | 'en' | 'sv')} />
                </div>
            </div>
        </div>
    </div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const menuBtn = document.querySelector('.mobile-menu-btn') as HTMLButtonElement | null
        const navMenu = document.querySelector('.nav-menu') as HTMLElement | null

        if (!menuBtn || !navMenu) return

        const setOpen = (open: boolean) => {
            menuBtn.classList.toggle('open', open)
            navMenu.classList.toggle('open', open)
            menuBtn.setAttribute('aria-expanded', open ? 'true' : 'false')
        }

        menuBtn.addEventListener('click', () => {
            setOpen(!navMenu.classList.contains('open'))
        })

        navMenu.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => setOpen(false))
        })
    })
</script>

<style>
    .nav {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        padding: 0;
        margin: 0;
        background-color: white;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }

    @media (max-width: 768px) {
        .nav {
            overflow-x: hidden;
        }
    }

    .nav-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        box-sizing: border-box;
        min-width: 0;
    }

    @media (min-width: 769px) {
        .nav-container {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: center;
            column-gap: 1rem;
        }

        .nav-menu {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.75rem;
            min-width: 0;
        }

        .nav-links {
            justify-content: flex-end;
            overflow: hidden;
        }
    }

    .nav-menu {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 1rem;
        flex: 1 1 auto;
        min-width: 0;
    }

    .nav-links {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.35rem;
        flex: 1 1 auto;
        min-width: 0;
    }

    .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
    }

    .navLink {
        color: black;
        text-decoration: none;
        padding: 0.5rem 0.35rem;
        border-bottom: 2px solid transparent;
        white-space: nowrap;
        transition:
            color 0.2s,
            border-color 0.2s;
    }

    .navLink:hover {
        border-bottom-color: var(--harmaa);
    }

    .navLink--active {
        color: var(--tummanvihrea);
        font-weight: 600;
        border-bottom-color: var(--hiekka);
    }

    .navLink--active:hover {
        border-bottom-color: var(--tummanvihrea);
    }

    @media (min-width: 769px) and (max-width: 1280px) {
        .navLink {
            padding: 0.5rem 0.2rem;
            font-size: 0.9375rem;
        }

        .nav-menu {
            gap: 0.75rem;
        }

        .nav-links {
            gap: 0.15rem;
        }

        .buttonContainer {
            gap: 0.35rem;
        }
    }

    .logo--active .logo-text h1 {
        color: var(--harmaa);
    }

    .buttonContainer {
        display: flex;
        gap: 0.5rem;
        margin: 0;
        flex-shrink: 0;
    }

    .logo {
        display: flex;
        align-items: center;
        text-decoration: none;
        margin: var(--space-base) var(--space-base) var(--space-base) 0;
        gap: var(--space-sm);
        transition: transform 0.2s ease;
        flex-shrink: 0;
        min-width: 0;
    }
    
    .logo:hover {
        transform: scale(1.02);
    }
    
    .logo-symbol {
        height: 40px;
        width: auto;
        object-fit: contain;
    }
    
    .logo-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }
    
    .logo-text h1 {
        font-size: 2rem;
        margin: 0;
        text-transform: uppercase;
        color: var(--tummanvihrea);
        font-weight: 600;
    }
    
    .logo-text h4 {
        font-size: 0.8rem;
        margin: 0;
        color: var(--harmaa);
        font-weight: 400;
    }

    .mobile-menu-btn {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 30px;
        height: 21px;
        padding: 0;
        border: 0;
        background: transparent;
        cursor: pointer;
        z-index: 10;
    }

    .mobile-menu-btn span {
        display: block;
        height: 3px;
        width: 100%;
        background-color: var(--tummanvihrea);
        border-radius: 3px;
        transition: all 0.3s ease;
    }

    .mobile-menu-btn.open span:nth-child(1) {
        transform: translateY(9px) rotate(45deg);
    }

    .mobile-menu-btn.open span:nth-child(2) {
        opacity: 0;
    }

    .mobile-menu-btn.open span:nth-child(3) {
        transform: translateY(-9px) rotate(-45deg);
    }

    @media (max-width: 768px) {
        .mobile-menu-btn {
            display: flex;
        }

        .nav-menu {
            position: fixed;
            top: 0;
            right: 0;
            height: 100vh;
            height: 100dvh;
            width: min(85vw, 320px);
            background-color: white;
            flex-direction: column;
            align-items: stretch;
            justify-content: flex-start;
            padding: 4.5rem 1.25rem 1.5rem;
            gap: 0;
            transform: translateX(100%);
            transition: transform 0.3s ease;
            box-shadow: -5px 0 15px rgba(0, 0, 0, 0.1);
            z-index: 5;
            box-sizing: border-box;
            overflow-y: auto;
        }

        .nav-menu.open {
            transform: translateX(0);
        }

        .nav-links {
            flex-direction: column;
            align-items: stretch;
            gap: 0;
            flex: none;
        }

        .navLink {
            width: 100%;
            padding: 1rem 0.75rem;
            border-bottom: 1px solid var(--vaaleanharmaa);
            border-left: 3px solid transparent;
            margin: 0;
            box-sizing: border-box;
        }

        .navLink--active {
            border-bottom-color: var(--vaaleanharmaa);
            border-left-color: var(--hiekka);
            background: rgba(172, 173, 148, 0.12);
        }

        .nav-actions {
            flex-direction: column;
            align-items: stretch;
            gap: 0.75rem;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--vaaleanharmaa);
        }

        .buttonContainer {
            flex-direction: column;
            width: 100%;
            margin: 0;
            gap: 0.5rem;
        }

        .buttonContainer :global(.tyov-btn) {
            width: 100%;
            box-sizing: border-box;
        }

        .logo-symbol {
            height: 32px;
        }
        
        .logo-text h1 {
            font-size: 1.5rem;
        }

        .logo-text h4 {
            font-size: 0.7rem;
        }
    }

    @media (max-width: 380px) {
        .logo-text h4 {
            display: none;
        }

        .logo {
            margin-right: 0;
        }

        .logo-text h1 {
            font-size: 1.25rem;
        }
    }
</style>
