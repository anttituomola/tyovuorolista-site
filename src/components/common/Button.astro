---
import { t } from '../../utils/translations'

const REGISTER_URL = 'https://app.tyovuorolista.fi/register'

const {
	text,
	backgroundColor,
	href,
	textColor,
	target,
	variant = 'custom',
	locale
} = Astro.props

const isPrimary = variant === 'primary'
const isSecondary = variant === 'secondary'

const linkHref =
	href ?? (isPrimary ? REGISTER_URL : undefined)

const displayText =
	text ??
	(isPrimary && locale
		? t('nav.register', locale as 'fi' | 'en' | 'sv')
		: 'Paina tästä!')

const opensAppRegister =
	typeof linkHref === 'string' && linkHref.includes('/register')

const linkTarget = target ?? (opensAppRegister ? '_blank' : '_self')
---

<a
	href={linkHref}
	target={linkTarget}
	class:list={[
		'tyov-btn',
		isPrimary && 'tyov-btn--primary',
		isSecondary && 'tyov-btn--secondary',
		!isPrimary && !isSecondary && 'tyov-btn--custom'
	]}
	style={
		!isPrimary && !isSecondary
			? `--btn-bg: ${backgroundColor || 'transparent'}; --btn-text: ${textColor || '#2d3a35'};`
			: undefined
	}
>
	{displayText}
</a>
