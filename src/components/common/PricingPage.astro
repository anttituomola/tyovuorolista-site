---
import RegisterButton from './RegisterButton.astro'
import { getTranslationObject } from '../../utils/translations'

const { locale = 'fi' } = Astro.props
const pricing = getTranslationObject('pages.pricing', locale as 'fi' | 'en' | 'sv')
const tiers = [
    pricing?.tiers?.tier1,
    pricing?.tiers?.tier2,
    pricing?.tiers?.tier3,
    pricing?.tiers?.tier4
].filter(Boolean)
---

<div class="wrapper pricingWrapper" id="pricingRoot" data-billing="yearly">
    <section class="hero">
        <span class="eyebrow">{pricing?.eyebrow}</span>
        <h1>{pricing?.title}</h1>
        <p class="subtitle">{pricing?.subtitle}</p>
        <div class="noticeRow">
            <span class="noticePill noticePillPrimary">{pricing?.priceNote}</span>
            <span class="noticePill">{pricing?.taxNote}</span>
        </div>
        <div class="billingToggle" role="tablist" aria-label={pricing?.toggleLabel}>
            <button
                type="button"
                class="billingToggleButton"
                data-billing-target="monthly"
                data-active="false"
            >
                {pricing?.monthlyLabel}
            </button>
            <button
                type="button"
                class="billingToggleButton"
                data-billing-target="yearly"
                data-active="true"
            >
                {pricing?.yearlyLabel}
            </button>
        </div>
        <p class="modeMessage monthlyOnly">{pricing?.monthlyMessage}</p>
        <p class="modeMessage yearlyOnly">{pricing?.yearlyMessage}</p>
    </section>

    <div class="pricing">
        {tiers.map((tier: any) => (
            <section class="pricingElement">
                <div class="cardHeader">
                    <span class="planBadge">{tier?.limit}</span>
                    <h2>{tier?.title}</h2>
                </div>

                <div class="priceBlock">
                    <p class="price monthlyOnly">{tier?.monthlyPrice}</p>
                    <p class="price yearlyOnly">{tier?.yearlyPrice}</p>
                    <p class="period monthlyOnly">{pricing?.monthlyPeriod}</p>
                    <p class="period yearlyOnly">{pricing?.yearlyPeriod}</p>
                    <p class="pricingUnit">{tier?.pricingUnit}</p>
                    {tier?.yearlySavings && (
                        <div class="savingsBlock">
                            <span class="savingsBadge yearlyOnly">{pricing?.yearlyBadge}</span>
                            <p class="savingsText">{tier?.yearlySavings}</p>
                        </div>
                    )}
                </div>

                <ul class="featureList">
                    <li class="featurePrimary">{tier?.limit}</li>
                    {tier?.features?.map((feature: string) => (
                        <li>{feature}</li>
                    ))}
                </ul>

                <div class="cardAction">
                    <RegisterButton locale={locale} />
                </div>
            </section>
        ))}
    </div>

    <p class="billingHint">{pricing?.billingHint}</p>
</div>

<script is:inline>
    const pricingRoot = document.getElementById('pricingRoot')

    if (pricingRoot) {
        const toggleButtons = pricingRoot.querySelectorAll('[data-billing-target]')

        const setBilling = billingMode => {
            pricingRoot.dataset.billing = billingMode

            toggleButtons.forEach(button => {
                button.setAttribute(
                    'data-active',
                    String(button.dataset.billingTarget === billingMode)
                )
            })
        }

        toggleButtons.forEach(button => {
            button.addEventListener('click', () => {
                setBilling(button.dataset.billingTarget || 'yearly')
            })
        })

        setBilling(pricingRoot.dataset.billing || 'yearly')
    }
</script>

<style>
    .pricingWrapper {
        padding: 0 var(--space-lg) var(--space-4xl);
    }

    .hero {
        max-width: 760px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-base);
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
        background: rgba(172, 173, 148, 0.25);
        color: var(--tummanvihrea);
        font-size: var(--text-sm);
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .subtitle {
        max-width: 680px;
        font-size: var(--text-lg);
    }

    .noticeRow {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-sm);
    }

    .noticePill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 1rem;
        border-radius: 999px;
        background: white;
        border: 1px solid rgba(74, 93, 88, 0.16);
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--tummanvihrea);
    }

    .noticePillPrimary {
        background: rgba(172, 173, 148, 0.2);
        border-color: rgba(172, 173, 148, 0.7);
    }

    .billingToggle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem;
        background: white;
        border: 1px solid rgba(74, 93, 88, 0.16);
        border-radius: 999px;
    }

    .billingToggleButton {
        appearance: none;
        border: none;
        background: transparent;
        color: var(--harmaa);
        padding: 0.75rem 1rem;
        border-radius: 999px;
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 600;
        cursor: pointer;
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            transform 0.2s ease;
    }

    .billingToggleButton[data-active='true'] {
        background: var(--tummanvihrea);
        color: white;
    }

    .billingToggleButton:hover {
        transform: translateY(-1px);
    }

    .modeMessage {
        max-width: 720px;
        margin: 0;
        font-size: var(--text-base);
        font-weight: 500;
        color: var(--tummanvihrea);
    }

    #pricingRoot[data-billing='monthly'] .yearlyOnly,
    #pricingRoot[data-billing='yearly'] .monthlyOnly {
        display: none;
    }

    .pricing {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.25rem;
        max-width: 1320px;
        width: 100%;
        margin: 2.5rem 0 1.5rem;
    }

    .pricingElement {
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(74, 93, 88, 0.16);
        border-radius: 1rem;
        padding: 1.5rem;
        background: white;
        box-shadow: 0 10px 30px rgba(45, 58, 53, 0.06);
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            border-color 0.2s ease;
        min-width: 0;
    }

    .pricingElement:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 38px rgba(45, 58, 53, 0.1);
        border-color: rgba(172, 173, 148, 0.9);
    }

    .cardHeader {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-sm);
        margin-bottom: var(--space-base);
    }

    .planBadge {
        display: inline-flex;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: rgba(45, 58, 53, 0.07);
        color: var(--tummanvihrea);
        font-size: var(--text-sm);
        font-weight: 600;
    }

    .priceBlock {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding-bottom: var(--space-lg);
        margin-bottom: var(--space-lg);
        border-bottom: 1px solid rgba(74, 93, 88, 0.12);
    }

    .price {
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 700;
        line-height: 1;
        color: var(--tummanvihrea);
        margin: 0;
    }

    .period {
        font-size: var(--text-sm);
        color: var(--harmaa);
        margin: 0;
    }

    .pricingUnit {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--tummanvihrea);
        margin: 0;
    }

    .savingsBlock {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        margin-top: var(--space-sm);
    }

    .savingsBadge {
        display: inline-flex;
        align-self: flex-start;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: rgba(45, 122, 72, 0.12);
        color: #1f6a3c;
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.01em;
        text-transform: uppercase;
    }

    .savingsText {
        font-size: var(--text-sm);
        color: var(--tummanvihrea);
        margin: 0;
    }

    .featureList {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex-grow: 1;
    }

    .featurePrimary {
        font-weight: 600;
        color: var(--tummanvihrea);
    }

    .featureList li {
        position: relative;
        padding-left: 1.5rem;
        color: var(--harmaa);
        line-height: 1.5;
    }

    .featureList li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.45rem;
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: var(--tummanvihrea);
    }

    .cardAction {
        margin-top: var(--space-xl);
        padding-top: var(--space-lg);
        border-top: 1px solid rgba(74, 93, 88, 0.12);
    }

    .billingHint {
        max-width: 760px;
        text-align: center;
        font-size: var(--text-sm);
        color: var(--harmaa);
    }

    @media (max-width: 1100px) {
        .pricing {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 640px) {
        .pricingWrapper {
            padding: 0 var(--space-base) var(--space-3xl);
        }

        .pricing {
            grid-template-columns: 1fr;
            margin: 2rem 0 1rem;
        }

        .pricingElement {
            padding: 1.25rem;
        }

        .noticeRow {
            flex-direction: column;
            width: 100%;
        }

        .billingToggle {
            width: 100%;
            box-sizing: border-box;
            justify-content: stretch;
        }

        .billingToggleButton {
            flex: 1 1 0;
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        .noticePill {
            width: 100%;
            box-sizing: border-box;
        }
    }
</style>
