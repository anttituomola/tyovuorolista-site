---
interface Props {
  code: 'fi' | 'en' | 'sv'
  class?: string
}

const { code, class: className } = Astro.props
---

<span class:list={['lang-flag', className]} aria-hidden="true">
  {
    code === 'fi' ? (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 12" role="presentation">
        <rect width="18" height="12" fill="#fff" />
        <rect x="5" width="3" height="12" fill="#003580" />
        <rect y="4.5" width="18" height="3" fill="#003580" />
      </svg>
    ) : code === 'en' ? (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 12" role="presentation">
        <rect width="18" height="12" fill="#012169" />
        <path stroke="#fff" stroke-width="2.4" d="M-1 0 19 12M19 0-1 12" />
        <path stroke="#c8102e" stroke-width="1.4" d="M-1 0 19 12M19 0-1 12" />
        <path stroke="#fff" stroke-width="3.6" d="M9 0v12M0 6h18" />
        <path stroke="#c8102e" stroke-width="2.2" d="M9 0v12M0 6h18" />
      </svg>
    ) : (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 12" role="presentation">
        <rect width="18" height="12" fill="#006aa7" />
        <rect x="5" width="2" height="12" fill="#fecc00" />
        <rect y="5" width="18" height="2" fill="#fecc00" />
      </svg>
    )
  }
</span>
