---
const { eyebrow, title, subtitle } = Astro.props
---

<section class="pageHero">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
</section>

<style>
    .pageHero {
        max-width: 760px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-base);
        margin: 0 auto var(--space-3xl);
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
        background: rgba(172, 173, 148, 0.25);
        color: var(--tummanvihrea);
        font-size: var(--text-sm);
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    h1 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 600;
        color: var(--tummanvihrea);
        margin: 0;
    }

    .subtitle {
        max-width: 680px;
        font-size: var(--text-lg);
        color: var(--harmaa);
        margin: 0;
        line-height: 1.6;
    }
</style>
