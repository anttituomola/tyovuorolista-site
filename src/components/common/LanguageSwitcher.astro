---
import LangFlagIcon from './LangFlagIcon.astro'
import { getLocaleFromAstro, getPathWithoutLocale, getLocalizedPath, convertToFinnishPath } from '../../utils/translations'

const locale = getLocaleFromAstro(Astro)
const currentPath = getPathWithoutLocale(Astro.url.pathname)

const languages = [
  { code: 'fi', name: 'Suomi' },
  { code: 'en', name: 'English' },
  { code: 'sv', name: 'Svenska' },
] as const

const current = languages.find((lang) => lang.code === locale) ?? languages[0]

const finnishOnlyPaths = ['/posts/', '/blogitekstit']

const isFinnishOnlyContent = (path: string) => {
  return finnishOnlyPaths.some((p) => path.startsWith(p) || path === p)
}

const getLocalizedUrl = (langCode: string) => {
  const finnishPath = convertToFinnishPath(currentPath)

  if (langCode === 'fi') {
    return finnishPath === '/' ? '/' : finnishPath
  }

  if (isFinnishOnlyContent(finnishPath)) {
    return `/${langCode}/not-available`
  }

  const localizedPath = getLocalizedPath(finnishPath, langCode as 'en' | 'sv')
  return localizedPath === '/' ? `/${langCode}` : localizedPath
}
---

<div class="lang-switcher" data-lang-switcher>
  <button
    type="button"
    class="lang-switcher__trigger"
    aria-expanded="false"
    aria-haspopup="menu"
    aria-controls="lang-switcher-menu"
    id="lang-switcher-trigger"
    aria-label={`${current.name} (${current.code.toUpperCase()})`}
  >
    <LangFlagIcon code={current.code} />
    <span class="lang-switcher__code">{current.code.toUpperCase()}</span>
    <span class="lang-switcher__chevron" aria-hidden="true"></span>
  </button>
  <ul
    class="lang-switcher__menu"
    id="lang-switcher-menu"
    role="menu"
    aria-labelledby="lang-switcher-trigger"
    hidden
  >
    {
      languages.map((lang) => {
        const isActive = locale === lang.code
        const url = getLocalizedUrl(lang.code)
        return (
          <li role="none">
            <a
              href={url}
              role="menuitem"
              class:list={['lang-switcher__option', { 'is-active': isActive }]}
              lang={lang.code}
              hreflang={lang.code}
              aria-label={lang.name}
              aria-current={isActive ? 'page' : undefined}
            >
              <LangFlagIcon code={lang.code} />
              <span class="lang-switcher__optionCode">{lang.code.toUpperCase()}</span>
            </a>
          </li>
        )
      })
    }
  </ul>
</div>

<script>
  const initLangSwitchers = () => {
    document.querySelectorAll('[data-lang-switcher]').forEach((root) => {
      const trigger = root.querySelector('.lang-switcher__trigger') as HTMLButtonElement | null
      const menu = root.querySelector('.lang-switcher__menu') as HTMLUListElement | null

      if (!trigger || !menu || root.getAttribute('data-lang-initialized') === 'true') {
        return
      }

      root.setAttribute('data-lang-initialized', 'true')

      const close = () => {
        menu.hidden = true
        trigger.setAttribute('aria-expanded', 'false')
        root.classList.remove('is-open')
      }

      const open = () => {
        menu.hidden = false
        trigger.setAttribute('aria-expanded', 'true')
        root.classList.add('is-open')
      }

      const toggle = () => {
        if (menu.hidden) {
          open()
        } else {
          close()
        }
      }

      trigger.addEventListener('click', (event) => {
        event.stopPropagation()
        toggle()
      })

      document.addEventListener('click', (event) => {
        if (!root.contains(event.target as Node)) {
          close()
        }
      })

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          close()
        }
      })
    })
  }

  initLangSwitchers()
  document.addEventListener('astro:page-load', initLangSwitchers)
</script>
