---
import Layout from '../layouts/Layout.astro'
const { frontmatter } = Astro.props
import Button from '../components/common/Button.astro'
import dayjs from 'dayjs'
---

<Layout>
    <div class="blogWrapper">
        {frontmatter.image && <img src={frontmatter.image.url} alt={frontmatter.image.alt} />}
        <h1>{frontmatter.title}</h1>
        <p class="metadata">Kirjoittanut {frontmatter.author}<br />
        Julkaistu {dayjs(frontmatter.pubDate).format('DD.MM.YYYY')}</p>
        <slot />
        <div style="margin: 4rem auto 2rem auto">
            <Button
                text="Kokeile Työvuorolistaa ilmaiseksi"
                backgroundColor="var(--tummanvihrea)"
                textColor="var(--vaaleanharmaa)"
                href="https://app.tyovuorolista.fi/CreateNewAccount"
            />
        </div>
    </div>
</Layout>

<style>
    .blogWrapper :global(h2) {
        margin-top: 4rem;
    }
    
    .blogWrapper :global(h2:first-of-type) {
        margin-top: 2rem;
    }
    
    .blogWrapper :global(h3) {
        margin-top: 2.5rem;
    }
    
    .blogWrapper :global(h4) {
        margin-top: 2rem;
    }
    
    .metadata {
        font-size: 0.9rem;
        color: #666;
        margin-top: 0.5rem;
        margin-bottom: 2rem;
    }

    /* Layout.astro sets global p { margin: 0 } — restore readable paragraph rhythm in posts */
    .blogWrapper :global(p:not(.metadata)) {
        margin-bottom: 1.15rem;
    }
    
    .blogWrapper :global(img) {
        border: 2px solid var(--vaaleanharmaa);
        border-radius: 8px;
        margin: var(--space-xl) 0;
        padding: 1rem;
        max-width: 100%;
        height: auto;
        display: block;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }
    
    .blogWrapper :global(img:first-child) {
        margin-top: var(--space-2xl);
    }
    
    .blogWrapper :global(video) {
        border: 2px solid var(--vaaleanharmaa);
        border-radius: 8px;
        margin: var(--space-xl) 0;
        padding: 1rem;
        max-width: 100%;
        height: auto;
        display: block;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        background-color: #000;
    }

    .blogWrapper :global(table) {
        width: 100%;
        max-width: 42rem;
        margin: 1.25rem 0 1.5rem;
        border-collapse: collapse;
        border: 1px solid rgba(52, 52, 52, 0.12);
        border-radius: 6px;
        overflow: hidden;
        font-size: 0.95rem;
        line-height: 1.45;
    }

    .blogWrapper :global(thead th) {
        background: rgba(52, 52, 52, 0.045);
        font-weight: 600;
    }

    .blogWrapper :global(th),
    .blogWrapper :global(td) {
        border: 1px solid rgba(52, 52, 52, 0.1);
        padding: 0.65rem 0.85rem;
        vertical-align: middle;
    }
</style>