---
import Layout from '../layouts/Layout.astro'
import PricingPage from '../components/common/PricingPage.astro'
import { getLocaleFromAstro, getTranslationObject } from '../utils/translations'

const locale = getLocaleFromAstro(Astro)
const pricing = getTranslationObject('pages.pricing', locale)
---

<Layout title={pricing?.title} description={pricing?.subtitle}>
    <PricingPage locale={locale} />
</Layout>
