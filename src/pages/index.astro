---
import '../styles/index-page.css'
import Layout from '../layouts/Layout.astro'
import Hero from '../components/mainPage/Hero.astro'
import FeatureHighlights from '../components/mainPage/FeatureHighlights.astro'
import DemoVideo from '../components/mainPage/DemoVideo.astro'
import CustomerStory from '../components/mainPage/CustomerStory.astro'
import HowItWorks from '../components/mainPage/HowItWorks.astro'
import MobileDemo from '../components/mainPage/MobileDemo.astro'
import Faq from '../components/mainPage/Faq.astro'
import NewestBlogPosts from '../components/mainPage/NewestBlogPosts.astro'
import ContactForm from '../components/mainPage/ContactForm.astro'
import { getLocaleFromAstro, getTranslationObject } from '../utils/translations'

const locale = getLocaleFromAstro(Astro)
const contactFormTranslations = getTranslationObject('contactForm', locale)
---

<Layout>
    <main class="index-page">
        <Hero locale={locale} />
        <FeatureHighlights locale={locale} />
        <DemoVideo locale={locale} />
        <CustomerStory locale={locale} />
        <HowItWorks locale={locale} />
        <MobileDemo locale={locale} />
        <Faq locale={locale} />
        {locale === 'fi' && <NewestBlogPosts />}
        <ContactForm locale={locale} translations={contactFormTranslations} />
    </main>
</Layout>
